# AutoClaw Proxy Environment Variables

# Optional API Key for proxy authentication
# If not set, proxy accepts all requests without authentication
# If set, clients must include: Authorization: Bearer <API_KEY>
API_KEY=

# Account routing strategy
# sticky: Same session/API key always uses same account (maximizes cache hit rate up to 96%)
# least-used: Distributes load evenly (default LRU behavior, lower cache hit ~1.7%)
# Default: sticky (recommended for cost optimization)
ROUTING_STRATEGY=sticky

# Examples:
# API_KEY=your-secret-key-here
# API_KEY=abc123xyz789
# ROUTING_STRATEGY=sticky
# ROUTING_STRATEGY=least-used
